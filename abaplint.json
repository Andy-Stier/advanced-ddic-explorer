{
    "global": {
    "files": "/src/**/*.*"
  },
    "dependencies": [
        {
            "url": "https://github.com",
            "folder": "/deps",
            "files": "/src/**/*.*"
        }
    ],
    "syntax": {
        "version": "v740sp08",
        "errorNamespace": "^(Z|Y)"
  },
    "rules": {
        "obsolete_statement": true,
        "check_syntax": true,
        "parser_error": true,
        "unknown_types": false,
        "unused_variables": true
  }
}
